# Brains MCP Server Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# Service Ports (used by docker-compose and Taskfile)
# =============================================================================
POSTGRES_PORT=9432
WEBGUI_PORT=9981
OLLAMA_URL=http://localhost:11434

# =============================================================================
# PostgreSQL Configuration
# =============================================================================
POSTGRES_USER=brains
POSTGRES_PASSWORD=brains_dev
POSTGRES_DB=brains

# Full connection URL (must match values above)
BRAINS_POSTGRES_URL=postgres://brains:brains_dev@localhost:9432/brains

# =============================================================================
# Database Backend
# =============================================================================
# Options: sqlite or postgres
# Default: sqlite (zero-configuration, uses ~/.brains/memories.db)
BRAINS_BACKEND=postgres

# SQLite Configuration (used when BRAINS_BACKEND=sqlite)
# Default: ~/.brains/memories.db
# BRAINS_SQLITE_PATH=~/.brains/memories.db

# PostgreSQL pool settings
# BRAINS_POSTGRES_MAX_CONNS=10
# BRAINS_POSTGRES_MIN_CONNS=2

# =============================================================================
# MCP Server Configuration
# =============================================================================
# Transport mode: http, sse, stdio
BRAINS_MCP_MODE=http

# Port for HTTP-based transports (http, sse)
BRAINS_MCP_PORT=8080

# =============================================================================
# Embedding Configuration (for recall)
# =============================================================================
BRAINS_OLLAMA_URL=http://localhost:11434
BRAINS_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error
BRAINS_LOG_LEVEL=info
