# Orchestrator Configuration
# Copy to .env.orchestrator and fill in values

# === Required ===
ORCH_LINEAR_API_KEY=lin_api_...
ORCH_GITHUB_TOKEN=ghp_...
ORCH_PROJECT_ID=                    # Linear project ID for concurrency scoping
ORCH_GITHUB_OWNER=morganhein
ORCH_GITHUB_REPO=zombiekit

# === Paths ===
ORCH_REPO_DIR=.                     # Git repo root (resolved at runtime)
ORCH_WORKTREES_ROOT=.claude/worktrees
ORCH_DB_PATH=.data/orchestrator.db

# === Optional (defaults shown) ===
ORCH_CALLBACK_PORT=8666
ORCH_POLL_INTERVAL=30s
ORCH_CONCURRENCY_LIMIT=1
ORCH_BASE_BRANCH=main
ORCH_TRACKING_LABEL=ai-managed
ORCH_BOT_USERNAME=
ORCH_CLOSED_PR_STATUS=cancelled
ORCH_LOG_LEVEL=info
ORCH_LOG_JSON=false
ORCH_SHUTDOWN_TIMEOUT=30s
